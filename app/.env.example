# Blockchain RPC endpoint
RPC_URL=http://localhost:8545

# Deployed SimpleStorage contract address (required)
CONTRACT_ADDRESS=

# Private key for signing transactions.
# The key below is the pre-funded "Alice" account from the local Besu dev network.
# Do NOT use this key on any public or shared network.
PRIVATE_KEY=0x8f2a55949038a9610f50fb23b5883af3b4ecb3c3bb792cbcefbd1542c692be63

# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/besu?sslmode=disable

# Server port
PORT=8080
